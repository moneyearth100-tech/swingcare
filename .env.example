# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# C2 upload analyze API (swingcare-api). LAN IP for device.
# EXPO_PUBLIC_ANALYZE_API_URL=http://172.30.1.43:8091

# Dashboard → Authentication → Providers
# - Anonymous: 캡처 세션 sync 폴백용 (기존)
# - Apple / Google / Kakao: Phase 1 온보딩 소셜 로그인
# Redirect URLs 에 앱 스킴 추가 예:
#   swingcare://auth/callback
#   exp+swingcare://auth/callback
#
# SQL (순서대로 적용):
#   supabase/migrations/001_swing_sessions.sql
#   supabase/migrations/002_users_profile.sql
#   … 006_swing_sessions_status_error.sql
# 로컬 persist: expo-file-system
#
# 익명 → 소셜: 앱이 linkIdentity로 동일 auth.users.id 유지
# 네이버: Supabase 네이티브 미지원 — UI만 노출, 커스텀 OAuth는 후속

# swingcare-api (server only — do not put service role in the app)
# SUPABASE_SERVICE_ROLE_KEY=
# REDIS_URL=redis://127.0.0.1:6379
# VISION_EXTRACT_URL=http://127.0.0.1:8090/v1/extract
# RESEND_API_KEY=          # pending 코칭 이메일 알림
# COACHING_NOTIFY_FROM=SwingCare <onboarding@resend.dev>

# SQL (코칭 마켓 — 대시보드에서 실행):
#   supabase/migrations/008_coaching_marketplace.sql
#   supabase/migrations/010_users_role.sql
#   supabase/migrations/011_coaches_seed.sql (선택)
