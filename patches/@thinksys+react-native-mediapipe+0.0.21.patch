+const startCameraRecording = async (): Promise<void> => {
+  if (typeof cameraRecordingModule?.startRecording !== 'function') {
+    throw new Error(
+      'MediaPipe camera recording is unavailable. Rebuild the native app.'
+    );
+  }
+  await cameraRecordingModule.startRecording();
+};
+
+const stopCameraRecording = async (): Promise<string> => {
+  if (typeof cameraRecordingModule?.stopRecording !== 'function') {
+    throw new Error(
+      'MediaPipe camera recording is unavailable. Rebuild the native app.'
+    );
+  }
+  const uri = await cameraRecordingModule.stopRecording();
+  if (typeof uri !== 'string' || uri.length === 0) {
+    throw new Error('MediaPipe camera recording returned no file.');
+  }
+  return uri;
+};
