+      1.0,
+      (double) VIDEO_FRAME_LONG_EDGE_PX / Math.max(width, height)
+    );
+    return new int[] {
+      Math.max(1, (int) Math.round(width * scale)),
+      Math.max(1, (int) Math.round(height * scale))
+    };
+  }
