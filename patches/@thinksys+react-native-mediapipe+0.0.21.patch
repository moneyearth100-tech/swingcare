+  private Bitmap getScaledFrameAtTime(
+    MediaMetadataRetriever retriever,
+    long timestampUs,
+    int targetWidth,
+    int targetHeight
+  ) {
+    if (
+      Build.VERSION.SDK_INT >= Build.VERSION_CODES.O_MR1 &&
+      targetWidth > 0 &&
+      targetHeight > 0
+    ) {
+      return retriever.getScaledFrameAtTime(
+        timestampUs,
+        MediaMetadataRetriever.OPTION_CLOSEST,
+        targetWidth,
+        targetHeight
+      );
+    }
+    Bitmap source = retriever.getFrameAtTime(
+      timestampUs,
+      MediaMetadataRetriever.OPTION_CLOSEST
+    );
+    if (source == null) {
+      return source;
+    }
+    int maxWidth = targetWidth > 0 ? targetWidth : VIDEO_FRAME_LONG_EDGE_PX;
+    int maxHeight = targetHeight > 0 ? targetHeight : VIDEO_FRAME_LONG_EDGE_PX;
+    if (source.getWidth() <= maxWidth && source.getHeight() <= maxHeight) {
+      return source;
+    }
+    double scale = Math.min(
+      (double) maxWidth / source.getWidth(),
+      (double) maxHeight / source.getHeight()
+    );
+    Bitmap scaled = Bitmap.createScaledBitmap(
+      source,
+      Math.max(1, (int) Math.round(source.getWidth() * scale)),
+      Math.max(1, (int) Math.round(source.getHeight() * scale)),
+      true
+    );
+    source.recycle();
+    return scaled;
+  }
+
+  private WritableMap createFrame(
+    long timestampMs,
+    List<NormalizedLandmark> detectedLandmarks
+  ) {
+    WritableArray landmarks = Arguments.createArray();
+    for (int index = 0; index < 33; index += 1) {
+      WritableMap point = Arguments.createMap();
+      if (index < detectedLandmarks.size()) {
+        NormalizedLandmark landmark = detectedLandmarks.get(index);
+        point.putDouble("x", landmark.x());
+        point.putDouble("y", landmark.y());
+        point.putDouble("z", landmark.z());
+        point.putDouble("visibility", landmark.visibility().orElse(0.0f));
+      } else {
+        point.putDouble("x", 0.0);
+        point.putDouble("y", 0.0);
+        point.putDouble("z", 0.0);
+        point.putDouble("visibility", 0.0);
+      }
+      landmarks.pushMap(point);
+    }
+    WritableMap frame = Arguments.createMap();
+    frame.putInt("timestampMs", (int) timestampMs);
+    frame.putArray("landmarks", landmarks);
+    return frame;
+  }
+
