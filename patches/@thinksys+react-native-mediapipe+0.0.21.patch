+        int frameCount = (int) Math.floor((double) durationMs / intervalMs) + 1;
+        WritableArray frames = Arguments.createArray();
+        int detectedFrameCount = 0;
+        long startedAtMs = SystemClock.elapsedRealtime();
+        int lastEmittedPercent = -1;
+
